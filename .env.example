# Sentinel — local environment file.
# Copy to .env for local development.  .env is git-ignored; this file is committed.
#
# PURPOSE OF .env IN DOCKER COMPOSE
# All SENTINEL__ settings that the API needs are already set in compose.yaml.
# This file is read ONLY by the vault-seed service, so any API keys you put here
# get written into Vault on `docker compose up` — the API then reads them from Vault.
#
# PURPOSE OF .env FOR LOCAL DEV (without Docker)
# Set all SENTINEL__ vars below so you can run `uv run uvicorn backend.main:app`
# against locally running Postgres/Vault/MinIO.

# ── User API keys (seeded into Vault by vault-seed on compose up) ─────────────
# Add real values when you have them. Leave commented out for local-only dev.
#
# GEMINI_API_KEY=...                     # SPEC-llm (#3) — primary LLM provider; seeded into Vault at secret/llm
# VIRUSTOTAL_API_KEY=...                 # SPEC-enrichment (#4) — threat intel
# SHODAN_API_KEY=...                     # SPEC-enrichment (#4) — threat intel
#
# Note: GEMINI_API_KEY is read by vault-seed and written to Vault at secret/llm.api_key.
# The API reads it from Vault at startup; never set it as a SENTINEL__ env var directly.
# Ollama (the local fallback) needs no API key.

# ── Local dev overrides (not used by Docker Compose, which sets these itself) ──
SENTINEL__APP__ENV=local
SENTINEL__APP__LOG_LEVEL=INFO

SENTINEL__VAULT__ADDR=http://localhost:8200
SENTINEL__VAULT__TOKEN=dev-root-token
SENTINEL__VAULT__KV_MOUNT=secret
SENTINEL__VAULT__REQUIRED_PATHS=["secret/minio","secret/llm"]

SENTINEL__POSTGRES__DSN=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

SENTINEL__MINIO__ENDPOINT_URL=http://localhost:9000
SENTINEL__MINIO__BUCKETS=["eval-reports","incident-snapshots"]

SENTINEL__STARTUP__DEPENDENCY_TIMEOUT_S=5.0
SENTINEL__STARTUP__CONNECT_RETRIES=5

# ── Observability (SPEC-observability #2) ──────────────────────────────────────
# SENTINEL__OBSERVABILITY__PRESIDIO_ENABLED=true
# SENTINEL__OBSERVABILITY__SPACY_MODEL=en_core_web_sm
# SENTINEL__OBSERVABILITY__ENTROPY_THRESHOLD=4.0
# SENTINEL__OBSERVABILITY__SPAN_ATTR_MAX_BYTES=8192
# SENTINEL__OBSERVABILITY__EXPORT_BATCH_SIZE=512
# SENTINEL__OBSERVABILITY__EXPORT_INTERVAL_MS=2000
# SENTINEL__OBSERVABILITY__TRACE_TO_STDOUT=false

# ── Ingest (SPEC-ingestion #4) ────────────────────────────────────────────────
# INGEST_WEBHOOK_TOKEN is seeded into Vault at secret/ingest by vault-seed.
# The API reads it from Vault at startup; never set SENTINEL__INGEST__WEBHOOK_VAULT_PATH directly.
#
# INGEST_WEBHOOK_TOKEN=change-me-dev-token
#
# SENTINEL__REDIS__URL=redis://localhost:6379/0
# SENTINEL__REDIS__QUEUE_KEY=queue:incidents
# SENTINEL__REDIS__PROCESSING_KEY=queue:processing
# SENTINEL__REDIS__DEDUP_PREFIX=dedup:
# SENTINEL__REDIS__DEQUEUE_BLOCK_S=5.0
#
# SENTINEL__INGEST__WEBHOOK_VAULT_PATH=secret/ingest
# SENTINEL__INGEST__MAX_ALERT_BYTES=262144
# SENTINEL__INGEST__DEDUP_WINDOW_S=300
# SENTINEL__INGEST__MAX_ATTEMPTS=3

# ── LLM Provider (SPEC-llm-provider #3) ───────────────────────────────────────
# Primary provider is Gemini (cloud); fallback is local Ollama.
# The GEMINI_API_KEY above is seeded into Vault; these settings configure the adapter.
# Docker Compose sets SENTINEL__LLM__OLLAMA_BASE_URL=http://ollama:11434 automatically.
# For local dev without Docker, set the Ollama base URL to your local Ollama instance.
#
# SENTINEL__LLM__PRIMARY=gemini
# SENTINEL__LLM__FALLBACK_ORDER=["gemini","ollama"]
# SENTINEL__LLM__REQUEST_TIMEOUT_S=30.0
# SENTINEL__LLM__MAX_RETRIES=2
# SENTINEL__LLM__GEMINI_MODEL=gemini-1.5-flash
# SENTINEL__LLM__GEMINI_VAULT_PATH=secret/llm
# SENTINEL__LLM__OLLAMA_BASE_URL=http://localhost:11434
# SENTINEL__LLM__OLLAMA_MODEL=qwen2:0.5b
