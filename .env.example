# Sentinel — local environment file.
# Copy to .env for local development.  .env is git-ignored; this file is committed.
#
# PURPOSE OF .env IN DOCKER COMPOSE
# All SENTINEL__ settings that the API needs are already set in compose.yaml.
# This file is read ONLY by the vault-seed service, so any API keys you put here
# get written into Vault on `docker compose up` — the API then reads them from Vault.
#
# PURPOSE OF .env FOR LOCAL DEV (without Docker)
# Set all SENTINEL__ vars below so you can run `uv run uvicorn backend.main:app`
# against locally running Postgres/Vault/MinIO.

# ── User API keys (seeded into Vault by vault-seed on compose up) ─────────────
# Add real values when you have them. Leave commented out for local-only dev.
#
# OPENAI_API_KEY=sk-...                  # SPEC-llm (#3) — LLM provider
# VIRUSTOTAL_API_KEY=...                 # SPEC-enrichment (#4) — threat intel
# SHODAN_API_KEY=...                     # SPEC-enrichment (#4) — threat intel

# ── Local dev overrides (not used by Docker Compose, which sets these itself) ──
SENTINEL__APP__ENV=local
SENTINEL__APP__LOG_LEVEL=INFO

SENTINEL__VAULT__ADDR=http://localhost:8200
SENTINEL__VAULT__TOKEN=dev-root-token
SENTINEL__VAULT__KV_MOUNT=secret
SENTINEL__VAULT__REQUIRED_PATHS=["secret/minio"]

SENTINEL__POSTGRES__DSN=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

SENTINEL__MINIO__ENDPOINT_URL=http://localhost:9000
SENTINEL__MINIO__BUCKETS=["eval-reports","incident-snapshots"]

SENTINEL__STARTUP__DEPENDENCY_TIMEOUT_S=5.0
SENTINEL__STARTUP__CONNECT_RETRIES=5
