# Argus — local environment file.
# Copy to .env for local development.  .env is git-ignored; this file is committed.
#
# PURPOSE OF .env IN DOCKER COMPOSE
# All ARGUS__ settings that the API needs are already set in compose.yaml.
# This file is read ONLY by the vault-seed service, so any API keys you put here
# get written into Vault on `docker compose up` — the API then reads them from Vault.
#
# PURPOSE OF .env FOR LOCAL DEV (without Docker)
# Set all ARGUS__ vars below so you can run `uv run uvicorn backend.main:app`
# against locally running Postgres/Vault/MinIO.

# ── Dashboard admin credentials (SPEC-dashboard #12) ─────────────────────────
# Seeded into Vault at secret/dashboard by vault-seed.
# Generate hash: python3 -c "import hashlib; print(hashlib.pbkdf2_hmac('sha256',b'yourpass',b'yoursalt',260000).hex())"
# ARGUS_ADMIN_PASSWORD_HASH=<pbkdf2-sha256-hex>   # change in production
# ARGUS_ADMIN_SALT=<random-salt>                  # change in production
# ARGUS_ADMIN_ITERATIONS=260000
# ARGUS_JWT_SECRET=<long-random-string>            # change in production!

# ── User API keys (seeded into Vault by vault-seed on compose up) ─────────────
# Add real values when you have them. Leave commented out for local-only dev.
#
# GEMINI_API_KEY=...                     # SPEC-llm (#3) — primary LLM provider; seeded into Vault at secret/llm
# VIRUSTOTAL_API_KEY=...                 # SPEC-enrichment (#4) — threat intel
# SHODAN_API_KEY=...                     # SPEC-enrichment (#4) — threat intel
#
# Note: GEMINI_API_KEY is read by vault-seed and written to Vault at secret/llm.api_key.
# The API reads it from Vault at startup; never set it as a ARGUS__ env var directly.
# Ollama (the local fallback) needs no API key.

# ── Local dev overrides (not used by Docker Compose, which sets these itself) ──
ARGUS__APP__ENV=local
ARGUS__APP__LOG_LEVEL=INFO

ARGUS__VAULT__ADDR=http://localhost:8200
ARGUS__VAULT__TOKEN=dev-root-token
ARGUS__VAULT__KV_MOUNT=secret
ARGUS__VAULT__REQUIRED_PATHS=["secret/minio","secret/llm"]

ARGUS__POSTGRES__DSN=postgresql+asyncpg://argus:argus@localhost:5432/argus

ARGUS__MINIO__ENDPOINT_URL=http://localhost:9000
ARGUS__MINIO__BUCKETS=["eval-reports","incident-snapshots"]

ARGUS__STARTUP__DEPENDENCY_TIMEOUT_S=5.0
ARGUS__STARTUP__CONNECT_RETRIES=5

# ── Observability (SPEC-observability #2) ──────────────────────────────────────
# ARGUS__OBSERVABILITY__PRESIDIO_ENABLED=true
# ARGUS__OBSERVABILITY__SPACY_MODEL=en_core_web_sm
# ARGUS__OBSERVABILITY__ENTROPY_THRESHOLD=4.0
# ARGUS__OBSERVABILITY__SPAN_ATTR_MAX_BYTES=8192
# ARGUS__OBSERVABILITY__EXPORT_BATCH_SIZE=512
# ARGUS__OBSERVABILITY__EXPORT_INTERVAL_MS=2000
# ARGUS__OBSERVABILITY__TRACE_TO_STDOUT=false

# ── Ingest (SPEC-ingestion #4) ────────────────────────────────────────────────
# INGEST_WEBHOOK_TOKEN is seeded into Vault at secret/ingest by vault-seed.
# The API reads it from Vault at startup; never set ARGUS__INGEST__WEBHOOK_VAULT_PATH directly.
#
# INGEST_WEBHOOK_TOKEN=change-me-dev-token
#
# ARGUS__REDIS__URL=redis://localhost:6379/0
# ARGUS__REDIS__QUEUE_KEY=queue:incidents
# ARGUS__REDIS__PROCESSING_KEY=queue:processing
# ARGUS__REDIS__DEDUP_PREFIX=dedup:
# ARGUS__REDIS__DEQUEUE_BLOCK_S=5.0
#
# ARGUS__INGEST__WEBHOOK_VAULT_PATH=secret/ingest
# ARGUS__INGEST__MAX_ALERT_BYTES=262144
# ARGUS__INGEST__DEDUP_WINDOW_S=300
# ARGUS__INGEST__MAX_ATTEMPTS=3

# ── LLM Provider (SPEC-llm-provider #3) ───────────────────────────────────────
# Primary provider is Gemini (cloud); fallback is local Ollama.
# The GEMINI_API_KEY above is seeded into Vault; these settings configure the adapter.
# Docker Compose sets ARGUS__LLM__OLLAMA_BASE_URL=http://ollama:11434 automatically.
# For local dev without Docker, set the Ollama base URL to your local Ollama instance.
#
# ARGUS__LLM__PRIMARY=gemini
# ARGUS__LLM__FALLBACK_ORDER=["gemini","ollama"]
# ARGUS__LLM__REQUEST_TIMEOUT_S=30.0
# ARGUS__LLM__MAX_RETRIES=2
# ARGUS__LLM__GEMINI_MODEL=gemini-1.5-flash
# ARGUS__LLM__GEMINI_VAULT_PATH=secret/llm
# ARGUS__LLM__OLLAMA_BASE_URL=http://localhost:11434
# ARGUS__LLM__OLLAMA_MODEL=qwen2:0.5b

# ── Memory / Graphiti (SPEC-memory #6) ────────────────────────────────────────
# Graphiti runs on Neo4j and uses the same GEMINI_API_KEY (secret/llm) as the LLM.
# No separate API key is needed — the embedder shares the key already in Vault.
# Docker Compose sets ARGUS__MEMORY__NEO4J_URI=bolt://neo4j:7687 automatically.
# For local dev without Docker, point neo4j_uri at your local Neo4j instance.
#
# ARGUS__MEMORY__ENABLED=true
# ARGUS__MEMORY__BACKEND=graphiti                    # graphiti | pgvector
# ARGUS__MEMORY__NEO4J_URI=bolt://localhost:7687
# ARGUS__MEMORY__NEO4J_VAULT_PATH=secret/memory     # username + password stored here
# ARGUS__MEMORY__RETRIEVAL_K=5
# ARGUS__MEMORY__RETRIEVAL_TIMEOUT_S=5.0
#
# Embedder — pick ONE at deploy time; do NOT switch after data is written.
# Vectors from different models are incompatible (different semantic spaces).
# If the chosen embedder is unavailable at startup, memory degrades to NullMemory.
#
# Option A — Gemini (default, cloud): shares GEMINI_API_KEY already in Vault.
# ARGUS__MEMORY__EMBEDDER_PROVIDER=gemini
# ARGUS__MEMORY__GEMINI_EMBEDDING_MODEL=text-embedding-004
#
# Option B — Ollama (local/air-gapped): uses OpenAI-compatible /v1/embeddings.
# ARGUS__MEMORY__EMBEDDER_PROVIDER=ollama
# ARGUS__MEMORY__OLLAMA_EMBEDDER_BASE_URL=http://ollama:11434
# ARGUS__MEMORY__OLLAMA_EMBEDDER_MODEL=nomic-embed-text
# ARGUS__MEMORY__OLLAMA_EMBEDDER_DIM=768
