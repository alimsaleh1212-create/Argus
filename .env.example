# Argus — copy to .env (git-ignored). Every variable is OPTIONAL:
# dev defaults keep the stack bootable from a fresh clone.
#
# Secrets policy: the app reads secrets ONLY from Vault. On `docker compose up`
# the one-shot vault-seed service reads this file and writes the values into
# Vault (deploy/vault/seed.sh). Nothing here is read by api/worker directly.

# ── Secrets seeded into Vault by vault-seed ───────────────────────────────────

# Gemini — primary LLM provider (secret/llm). Omit to run on the local Ollama
# fallback only.
# GEMINI_API_KEY=

# Token Wazuh must present on POST /ingest/wazuh (secret/ingest).
# Default: dev-webhook-token
# INGEST_WEBHOOK_TOKEN=

# On-demand threat intel (secret/intel) — optional; omit to disable lookups.
# INTEL_API_KEY=

# Dashboard admin login (secret/dashboard). Dev default: admin / argus-admin-2026
# Generate a new hash:
#   python3 -c "import hashlib; print(hashlib.pbkdf2_hmac('sha256', b'PASSWORD', b'SALT', 260000).hex())"
# ARGUS_ADMIN_PASSWORD_HASH=
# ARGUS_ADMIN_SALT=
# ARGUS_ADMIN_ITERATIONS=260000
# ARGUS_JWT_SECRET=

# ── Local dev outside Docker (`uv run uvicorn backend.main:app`) ──────────────
# Settings auto-load this file (backend/infra/config.py). Connection defaults
# point at Docker-DNS hostnames, so override them with localhost here.
# Not used by Docker Compose. All other settings: see config.py defaults.

# ARGUS__APP__ENV=local
# ARGUS__VAULT__ADDR=http://localhost:8200
# ARGUS__VAULT__REQUIRED_PATHS=["secret/minio","secret/llm","secret/ingest","secret/dashboard"]
# ARGUS__POSTGRES__DSN=postgresql+asyncpg://argus:argus@localhost:5432/argus
# ARGUS__MINIO__ENDPOINT_URL=http://localhost:9000
# ARGUS__MINIO__BUCKETS=["argus-evidence","argus-exports"]
# ARGUS__REDIS__URL=redis://localhost:6379/0
# ARGUS__LLM__FALLBACK_ORDER=["gemini","ollama"]
# ARGUS__LLM__OLLAMA_BASE_URL=http://localhost:11434
# ARGUS__LLM__GEMINI_MODEL=gemini-2.5-flash
# ARGUS__LLM__OLLAMA_MODEL=gemma4:31b-cloud
# ARGUS__MEMORY__NEO4J_URI=bolt://localhost:7687
# ARGUS__MEMORY__EMBEDDER_PROVIDER=gemini
# ARGUS__MEMORY__GEMINI_EMBEDDING_MODEL=text-embedding-004
# ARGUS__MEMORY__OLLAMA_EMBEDDER_MODEL=nomic-embed-text
# ARGUS__MEMORY__OLLAMA_EMBEDDER_DIM=768
# Reranker fallback chain (JSON list) — gemini-only by default; ["gemini","ollama"]
# falls back to ollama (reusing llm.ollama_model, no extra pull) if gemini is down
# ARGUS__MEMORY__CROSS_ENCODER_ORDER=["gemini"]
# spaCy model for Presidio PII detection (baked into the image; sm by default)
# ARGUS__OBSERVABILITY__SPACY_MODEL=en_core_web_sm
# ARGUS__STARTUP__SKIP_VAULT=false

# Feedback loop (#16) — all values optional; defaults are production-like.
# ARGUS__FEEDBACK__ENABLED=true
# ARGUS__FEEDBACK__ESCALATE_ON=["regressed","unverified"]
# ARGUS__FEEDBACK__SEVERITY_BIAS=bump_one
# ARGUS__FEEDBACK__PREFER_STRONGER_PLAYBOOK=true
# ARGUS__FEEDBACK__MAX_INDICATORS=5
# ARGUS__FEEDBACK__OUTCOME_FACT_TYPE=remediation_outcome

# Response/remediation stage — all values optional.
# Approval timeout before the sweeper expires a pending approval (default 1800s).
# ARGUS__RESPONSE__APPROVAL_TIMEOUT_S=1800
# Interval between approval-expiry sweeps (default 60s).
# ARGUS__RESPONSE__SWEEP_INTERVAL_S=60
# Mock executor probe mode for the verification tail (demo/dev only, default "expected"):
#   "expected"      → probes report the intended post-state (verdict VERIFIED).
#   "inconclusive"  → probes can't read post-state (verdict UNVERIFIED → escalated).
#   "regressed"     → probes report the threat persists (verdict REGRESSED → escalated).
# ARGUS__RESPONSE__VERIFY_PROBE_MODE=expected
